<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.ranni.assistant</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/python3</string>
        <string>/opt/ranni/core/main.py</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/opt/ranni</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/opt/ranni/data/stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/opt/ranni/data/stderr.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/opt/ranni/venv/bin</string>
        <key>PYTHONUNBUFFERED</key>
        <string>YES</string>
    </dict>
</dict>
</plist>
